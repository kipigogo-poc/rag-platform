# ──────────────────────────────────────────
# Groq — LLM for notes, quiz, and chat (FREE, no geo restrictions)
# Get your key at: https://console.groq.com
# ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# Optional: default is llama-3.1-8b-instant (best for free-tier limits)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Gemini (embeddings fallback if JINA_API_KEY is not set)
GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────
# Supabase (Vector DB — FREE tier)
# Project URL from: Settings > API
# ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ──────────────────────────────────────────
# Auth (shared with Next.js frontend)
# Generate with: openssl rand -base64 32
# Must match AUTH_SECRET in frontend/.env.local
# ──────────────────────────────────────────
AUTH_SECRET=your_32_byte_base64_secret_here

# ──────────────────────────────────────────
# App Config
# ──────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Allowed origin(s) for CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000

# Max upload size in bytes (default 20 MB)
MAX_FILE_SIZE=20971520

# Jina AI API key for embeddings (free 1M tokens at jina.ai)
# Recommended when Gemini embedding API is restricted in your region (e.g. Philippines)
# Falls back to Gemini embeddings if not set
JINA_API_KEY=your_jina_api_key_here

# Telegram Bot (optional — get token from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
