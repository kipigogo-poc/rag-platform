# ──────────────────────────────────────────
# Google Gemini (Google AI Studio — FREE)
# Get your key at: https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────
# Supabase (Vector DB — FREE tier)
# Project URL from: Settings > API
# ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ──────────────────────────────────────────
# Auth (shared with Next.js frontend)
# Generate with: openssl rand -base64 32
# Must match AUTH_SECRET in frontend/.env.local
# ──────────────────────────────────────────
AUTH_SECRET=your_32_byte_base64_secret_here

# ──────────────────────────────────────────
# App Config
# ──────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Allowed origin(s) for CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000

# Max upload size in bytes (default 20 MB)
MAX_FILE_SIZE=20971520

# HuggingFace token for embeddings (free at huggingface.co/settings/tokens)
# Recommended for users in regions where Gemini embedding API is restricted (e.g. Philippines)
# Falls back to Gemini embeddings if not set
HF_TOKEN=your_huggingface_token_here

# Telegram Bot (optional — get token from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
